---
// Curator — marketing landing page (static Astro).
// PLACEHOLDERS to set before launch (see README): price, download URLs,
// Paddle checkout link, real domain in astro.config.mjs + the OG/meta below.
const yearlyPrice = "$9.99"; // yearly subscription
const lifetimePrice = "$80"; // one-time, current major version only
const trialDays = 14;
// Paddle checkout — LIVE/production values (account verified, accepting real
// payments). Ensure the yourcurator.app domain stays approved in the Paddle
// dashboard so the hosted checkout keeps loading.
const paddleEnv = "production";
const paddleToken = "live_a5cec268b42f7c3810b9aa81b3d";
const yearlyPriceId = "pri_01kv3p9gv7hj74njs8e3448t13";
const lifetimePriceId = "pri_01kv3paynp2j0jeagp6jn2e34f";
const siteUrl = "https://yourcurator.app";

// ── LAUNCH SWITCH ───────────────────────────────────────────────────────────
// The product hasn't publicly launched yet, so every buy/download CTA is
// replaced with a register-your-interest link and Paddle checkout is not
// loaded. ON LAUNCH DAY: flip `launched` in src/config.ts and fill in
// `downloadUrls` below (signed installers on GitHub Releases / R2) — that
// restores the Buy buttons, the platform download buttons and the Paddle
// script in one flip, site-wide.
import { launched } from "../config";
const downloadUrls = { mac: "#", windows: "#", linux: "#" }; // set at launch
// Register-interest capture: an inline Web3Forms form (submissions are emailed
// to the address the access key was created for — webform@neutrade.co.uk).
// Set w3fAccessKey from the app.web3forms.com dashboard to activate the form;
// while it's empty the section falls back to a pre-filled support email so the
// button is never dead. NOTE: the fallback depends on Cloudflare Email Routing
// forwarding support@yourcurator.app.
const w3fAccessKey = "8682307c-c0d2-4032-a98b-c13be042d5ee"; // from app.web3forms.com (account: webform@neutrade.co.uk)
const interestMailto = `mailto:support@yourcurator.app?subject=${encodeURIComponent(
  "Curator — register my interest",
)}&body=${encodeURIComponent(
  "Hi — please let me know when Curator launches.\n\nMy platform: macOS / Windows / Linux",
)}`;
// ────────────────────────────────────────────────────────────────────────────
const ogImage = `${siteUrl}/og-card.png`; // absolute — social scrapers need a full URL
// Numeric prices for the structured-data offers (Schema.org wants a bare number +
// currency, not the "$9.99" display strings above). Keep these in step with the
// display prices and the Paddle price ids.
const yearlyPriceValue = "9.99";
const lifetimePriceValue = "80";
const priceCurrency = "USD";

// Structured data (JSON-LD). Helps Google show Curator as a software product with
// its platforms, price and publisher, rather than a generic web page. No fake
// ratings — an aggregateRating is deliberately omitted until there are real reviews.
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#org`,
      name: "Curator",
      url: siteUrl,
      logo: `${siteUrl}/logo.png`,
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      url: siteUrl,
      name: "Curator",
      publisher: { "@id": `${siteUrl}/#org` },
      inLanguage: "en-GB",
    },
    {
      "@type": "SoftwareApplication",
      name: "Curator",
      applicationCategory: "MultimediaApplication",
      operatingSystem: "macOS, Windows, Linux",
      url: siteUrl,
      downloadUrl: `${siteUrl}/#download`,
      softwareVersion: "1.0.0",
      description:
        "Curator renames messy media downloads into clean, correctly-named files and files them into a browsable collection. A fast, native desktop app and a modern FileBot alternative.",
      publisher: { "@id": `${siteUrl}/#org` },
      // Pre-launch the offers are marked PreOrder; flips to InStock with `launched`.
      offers: [
        {
          "@type": "Offer",
          name: "Free",
          price: "0",
          priceCurrency,
          description: "Rename your media and match it online — real titles, episode numbers and posters — free forever. No account, no card, no expiry.",
          url: `${siteUrl}/#pricing`,
          availability: launched ? "https://schema.org/InStock" : "https://schema.org/PreOrder",
        },
        {
          "@type": "Offer",
          name: "Yearly",
          price: yearlyPriceValue,
          priceCurrency,
          category: "subscription",
          url: `${siteUrl}/#pricing`,
          availability: launched ? "https://schema.org/InStock" : "https://schema.org/PreOrder",
        },
        {
          "@type": "Offer",
          name: "Lifetime",
          price: lifetimePriceValue,
          priceCurrency,
          url: `${siteUrl}/#pricing`,
          availability: launched ? "https://schema.org/InStock" : "https://schema.org/PreOrder",
        },
      ],
    },
  ],
};
// `?v=` query suffixes are cache-busters: several feature images were refreshed
// in place (same filename), so a bumped version forces browsers to re-fetch.
type Feature = {
  id: string; eyebrow: string; title: string; body: string;
  img?: string; slides?: string[]; alt: string; bullets: string[]; note?: string;
};
const features: Feature[] = [
  {
    id: "matching",
    eyebrow: "Smart matching",
    title: "Messy filenames in. Correct names out.",
    body:
      "Drop in a folder of cryptically-named downloads and Curator works out what each one is — the right show, the right film, the real episode title — using TheTVDB, TheMovieDB and Trakt. It shows you a confidence score for every match, and when it's not sure, you pick from a list of posters rather than guessing.",
    img: "/img/03-match-list-light.png?v=2",
    alt: "Curator matching messy filenames to clean, correctly-named episodes",
    bullets: ["Real episode titles, not just S01E02", "A poster picker when a match is uncertain", "Match a whole season in one go"],
  },
  {
    id: "collection",
    eyebrow: "Your collection",
    title: "A library worth browsing.",
    body:
      "Everything you file lands in a poster wall that actually feels like a collection — sorted, searchable, with quality and codec badges read from the real files and community ratings on every tile. It's the part of organising your media that's usually a spreadsheet, made into something you'll open for fun.",
    img: "/img/05-collection-light.png?v=2",
    alt: "Curator's collection poster wall with quality badges and ratings",
    bullets: ["4K / HD / codec badges from the actual file", "★ ratings on every title", "Bring your own artwork any time"],
    note: "A note while we're getting started: TV artwork is live today, but full studio movie posters switch on a little after launch. Until then films are still matched and named correctly — they just show a placeholder you can swap for your own poster.",
  },
  {
    id: "completion",
    eyebrow: "Completion tracking",
    title: "See exactly what you're missing.",
    body:
      "Curator knows how many episodes a season should have, so it can tell you what you've got and what you haven't — per show, per season, down to the individual episode. The missing-episodes report turns that into a simple shopping list for finishing a collection.",
    slides: ["/img/06-completion-seasons-light.png?v=2", "/img/missing-episodes.png"],
    alt: "Curator's per-season completion percentages and its missing-episodes report",
    bullets: ["% owned for every show and season", "A grid of the gaps you're missing", "Export a 'what to get next' list"],
  },
  {
    id: "presentation",
    eyebrow: "Presentation mode",
    title: "Put it on the big screen.",
    body:
      "A full-screen, slowly-crossfading wall of your own posters. Lovely on a TV or a spare monitor, and a quiet reminder of just how much you've built.",
    slides: [
      "/img/pres-1.png",
      "/img/pres-2.png",
      "/img/pres-3.png",
      "/img/pres-4.png",
      "/img/pres-5.png",
    ],
    alt: "Curator presentation mode cycling through full-screen posters",
    bullets: ["Full-screen poster slideshow", "Runs on a second display", "Your library, as a screensaver"],
  },
  {
    id: "control",
    eyebrow: "Your rules",
    title: "Organised exactly how you want.",
    body:
      "Choose whether each item gets its own tidy folder or is renamed in place — and watch the new name update live as you toggle. Move, copy or overwrite. Use the Smart preset that tells TV from film automatically, or pin your own. Nothing is ever overwritten by accident, and every rename is a single click to undo.",
    img: "/img/settings.png",
    alt: "Curator's settings — placement, folder, database and theme defaults",
    bullets: ["Folder structure on or off — preview updates live", "Move · Copy · Overwrite", "One-click undo, never clobbers a file"],
  },
  {
    id: "health",
    eyebrow: "Know your library",
    title: "A health check for your whole collection.",
    body:
      "Curator scans everything you've filed and tells you what needs attention — broken paths, unmatched files, gaps in a season, missing metadata — in a single pass. Then it breaks your storage down by decade, resolution and content type, and lists your biggest files so you can see where the space is going.",
    slides: ["/img/health-light.png", "/img/storage-light.png"],
    alt: "Curator's library-health dashboard and storage analytics",
    bullets: ["Broken paths, unmatched files and missing episodes at a glance", "Storage by decade, resolution and content type", "Find your largest files and bloated encodes"],
  },
];

// Secondary features — shown as a compact grid rather than full alternating
// blocks. These are the power features that live in settings/panels; the grid
// keeps them visible without six near-identical form screenshots.
type MoreFeature = { icon: string; title: string; body: string };
const moreFeatures: MoreFeature[] = [
  {
    icon:
      '<path d="M21 12a9 9 0 1 1-3-6.7"/><polyline points="21 3 21 9 15 9"/>',
    title: "Automation",
    body:
      "Watch a downloads folder and Curator files new media the moment it lands. Scheduled scans, automatic Plex / Jellyfin / Emby refresh, plus webhooks and hooks for Sonarr, qBittorrent and your own scripts.",
  },
  {
    icon:
      '<polyline points="20 6 9 17 4 12"/><path d="M14 4h6v6" opacity=".45"/>',
    title: "Smart organisation",
    body:
      "Duplicate detection spots the same episode filed twice — keep the highest quality automatically. Quality-upgrade prompts, custom folder templates and rule-based routing keep everything tidy.",
  },
  {
    icon:
      '<rect x="3" y="5" width="18" height="14" rx="2"/><line x1="7" y1="15" x2="11" y2="15"/><line x1="14" y1="15" x2="17" y2="15"/>',
    title: "Subtitles, NFO & artwork",
    body:
      "Auto-download subtitles in your languages from OpenSubtitles, write NFO sidecars, and embed poster art into your files with ffmpeg — ready for Plex, Kodi and Jellyfin.",
  },
  {
    icon:
      '<polygon points="12 3 20 7.5 20 16.5 12 21 4 16.5 4 7.5 12 3"/><line x1="12" y1="12" x2="12" y2="21" opacity=".45"/>',
    title: "Anime, done right",
    body:
      "AniDB exact-hash matching, absolute-numbered shows like One Piece and Bleach named correctly, and preferred fansub-group handling when you have more than one copy.",
  },
  {
    icon:
      '<polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>',
    title: "Power tools",
    body:
      "Persistent history with multi-batch undo, multiple profiles for different libraries, a command line, and rhai scripting macros for when you want the last word on a name.",
  },
];
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>Curator — Media File Renamer & Organiser | FileBot Alternative</title>
    <meta
      name="description"
      content="Curator renames messy media downloads into clean, correctly-named files and files them into a collection worth browsing. A fast, native app for macOS, Windows and Linux, and a modern FileBot alternative."
    />
    <meta name="theme-color" content="#2f6bff" />
    <link rel="canonical" href={`${siteUrl}/`} />
    <meta property="og:site_name" content="Curator" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:title" content="Curator — tidy media, automatically" />
    <meta
      property="og:description"
      content="Rename messy downloads into clean, correctly-named files and build a collection worth browsing. Native. Fast. Yours."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}/`} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Curator — tidy media, automatically" />
    <meta
      name="twitter:description"
      content="Rename messy downloads into clean, correctly-named files and build a collection worth browsing. Native. Fast. Yours."
    />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <a class="skip" href="#features">Skip to content</a>

    <header class="nav">
      <a class="brand" href="/">
        <img src="/logo.png" width="28" height="28" alt="" />
        <span>Curator</span>
      </a>
      <nav class="nav-links">
        <a href="#features">Features</a>
        <a href="#pricing">Pricing</a>
        <a href="/news">News</a>
        <a href="#download">{launched ? "Download" : "Get notified"}</a>
        <a href="/contact">Contact</a>
        <a class="btn btn-sm" href="#download">{launched ? "Download free" : "Register interest"}</a>
      </nav>
    </header>

    <main>
      <!-- HERO -->
      <section class="hero">
        <p class="eyebrow">A modern alternative to FileBot</p>
        <h1>Tidy media,<br /><span class="grad">automatically.</span></h1>
        <p class="lead">
          Curator renames cryptic downloads into clean, correctly-named files —
          matched online for real titles, episode numbers and posters — then files
          them into a collection worth browsing. Native and fast on macOS, Windows
          and Linux. No browser in disguise, no Java.
        </p>
        <div class="cta-row">
          {launched ? (
            <a class="btn btn-lg" href="#download">Download free</a>
          ) : (
            <a class="btn btn-lg" href="#download">Register your interest</a>
          )}
          <a class="btn btn-lg btn-ghost" href="#pricing">See Premium</a>
        </div>
        <p class="cta-note">
          {launched
            ? `Rename and match online, free forever · ${trialDays}-day Premium trial, no card required`
            : `Launching soon · Rename and match online, free forever · ${trialDays}-day Premium trial, no card required`}
        </p>

        <div class="hero-media">
          <video
            autoplay
            loop
            muted
            playsinline
            preload="auto"
            poster="/video/curator-hero-poster.png?v=2"
            aria-label="Curator tidying a folder of messy downloads into clean, correctly-named files and a collection poster wall"
          >
            <source src="/video/curator-hero.webm?v=2" type="video/webm" />
            <source src="/video/curator-hero.mp4?v=2" type="video/mp4" />
          </video>
        </div>
      </section>

      <!-- FEATURES -->
      <section id="features" class="features">
        {
          features.map((f, i) => (
            <div class={`feature ${i % 2 ? "reverse" : ""}`} id={f.id}>
              <div class="feature-copy">
                <p class="eyebrow">{f.eyebrow}</p>
                <h2>{f.title}</h2>
                <p>{f.body}</p>
                <ul class="ticks">
                  {f.bullets.map((b) => (
                    <li>{b}</li>
                  ))}
                </ul>
                {f.note && <p class="feature-note">{f.note}</p>}
              </div>
              <div class={f.slides ? "feature-shot slideshow" : "feature-shot"}>
                {
                  f.slides ? (
                    f.slides.map((s, si) => (
                      <img src={s} alt={f.alt} class={si === 0 ? "active" : ""} />
                    ))
                  ) : (
                    <img src={f.img} alt={f.alt} loading="lazy" />
                  )
                }
              </div>
            </div>
          ))
        }
      </section>

      <!-- MORE FEATURES (compact grid) -->
      <section class="more">
        <p class="eyebrow center">And a lot more</p>
        <h2 class="center">Everything else a power library needs.</h2>
        <div class="more-grid">
          {
            moreFeatures.map((m) => (
              <div class="more-card">
                <svg class="more-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={m.icon} />
                <h3>{m.title}</h3>
                <p>{m.body}</p>
              </div>
            ))
          }
        </div>
      </section>

      <!-- NATIVE / TRUST STRIP -->
      <section class="strip">
        <div class="strip-grid">
          <div>
            <h3>Genuinely native</h3>
            <p>Built with Rust, not a packaged web browser. A real installed app of around 12&nbsp;MB that opens instantly.</p>
          </div>
          <div>
            <h3>Private by default</h3>
            <p>Your library lives on your machine. No accounts to browse it, and you can export everything to move computers whenever you like.</p>
          </div>
          <div>
            <h3>Safe renames</h3>
            <p>Curator never overwrites a file by accident, checks the destination first, and every batch is one click to undo.</p>
          </div>
          <div>
            <h3>macOS · Windows · Linux</h3>
            <p>One app, every desktop. Light and dark, and it looks at home on each.</p>
          </div>
        </div>
      </section>

      <!-- PRICING -->
      <section id="pricing" class="pricing">
        <p class="eyebrow center">Pricing</p>
        <h2 class="center">Free to rename and match. Premium for the rest.</h2>
        <p class="price-sub center">
          {launched
            ? `Renaming and online matching are free forever. Try everything else free for ${trialDays} days — no card required — then stay on Free or upgrade.`
            : `Renaming and online matching will be free forever. At launch you'll be able to try everything else free for ${trialDays} days — no card required — then stay on Free or upgrade.`}
        </p>
        <div class="price-grid">
          <div class="price-card">
            <p class="plan-name">Free</p>
            <div class="price-head">
              <span class="price">$0</span>
              <span class="per">forever</span>
            </div>
            <ul class="ticks">
              <li>Rename TV, film &amp; anime with live preview</li>
              <li>Online matching — real titles, episode numbers &amp; posters via TheTVDB &amp; Trakt</li>
              <li>Smart, TV and Movie presets</li>
              <li>Move, copy &amp; safe renames — one-click undo</li>
              <li>Offline filename parsing when you're not connected</li>
              <li>No account, no card, no expiry</li>
            </ul>
            {launched ? (
              <a class="btn btn-lg full btn-ghost" href="#download">Download free</a>
            ) : (
              <a class="btn btn-lg full btn-ghost" href="#download">Register interest</a>
            )}
            <p class="price-foot">{launched ? "Yours to keep. Upgrade any time." : "Available at launch. Yours to keep."}</p>
          </div>
          <div class="price-card">
            <p class="plan-name">Premium Yearly</p>
            <div class="price-head">
              <span class="price">{yearlyPrice}</span>
              <span class="per">/ year</span>
            </div>
            <ul class="ticks">
              <li>Everything in Free, plus:</li>
              <li>The full collection, completion tracking &amp; presentation mode</li>
              <li>Automation, duplicate &amp; quality-upgrade detection, health reports</li>
              <li>Subtitles, NFO &amp; artwork, anime, CLI &amp; scripting</li>
              <li>Use it on 2 of your computers · every update while subscribed</li>
            </ul>
            {launched ? (
              <>
                <button class="btn btn-lg full buy" data-price={yearlyPriceId}>Buy yearly</button>
                <a class="btn btn-lg full btn-ghost" href="#download">Start free trial</a>
              </>
            ) : (
              <a class="btn btn-lg full" href="#download">Register your interest</a>
            )}
            <p class="price-foot">
              {launched ? `Then ${yearlyPrice}/year. Cancel any time.` : `On sale at launch — ${yearlyPrice}/year, cancel any time.`}
            </p>
          </div>
          <div class="price-card featured">
            <p class="plan-name">Premium Lifetime <span class="badge">Best value</span></p>
            <div class="price-head">
              <span class="price">{lifetimePrice}</span>
              <span class="per">once</span>
            </div>
            <ul class="ticks">
              <li>Everything in Premium Yearly</li>
              <li>Pay once — no renewals</li>
              <li>Free updates for the current major version</li>
              <li>Use it on 2 of your computers</li>
            </ul>
            {launched ? (
              <>
                <button class="btn btn-lg full buy" data-price={lifetimePriceId}>Buy lifetime</button>
                <a class="btn btn-lg full btn-ghost" href="#download">Start free trial</a>
              </>
            ) : (
              <a class="btn btn-lg full" href="#download">Register your interest</a>
            )}
            <p class="price-foot">
              {launched
                ? `One payment of ${lifetimePrice}. Covers all of the current major version.`
                : `On sale at launch — one payment of ${lifetimePrice}, covers all of the current major version.`}
            </p>
          </div>
        </div>
      </section>

      <!-- DOWNLOAD / REGISTER INTEREST (pre-launch) -->
      <section id="download" class="download">
        {launched ? (
          <>
            <h2 class="center">Get Curator</h2>
            <p class="center muted">Free to download, rename and match online. Premium unlocks free for {trialDays} days — no card. Pick your platform.</p>
            <div class="dl-row">
              <a class="btn btn-lg" href={downloadUrls.mac}>macOS</a>
              <a class="btn btn-lg" href={downloadUrls.windows}>Windows</a>
              <a class="btn btn-lg" href={downloadUrls.linux}>Linux</a>
            </div>
            <p class="center cta-note">Apple Silicon · Windows 10/11 · AppImage</p>
          </>
        ) : (
          <>
            <p class="eyebrow center">Launching soon</p>
            <h2 class="center">Get Curator</h2>
            <p class="center muted">
              Curator is in final testing and launches soon on macOS, Windows and Linux.
              Register your interest and you'll be the first to know when it ships —
              nothing else, no spam.
            </p>
            {w3fAccessKey ? (
              <form
                id="interest-form"
                class="interest-form"
                action="https://api.web3forms.com/submit"
                method="POST"
              >
                <input type="hidden" name="access_key" value={w3fAccessKey} />
                <input type="hidden" name="subject" value="Curator — register my interest" />
                <input type="hidden" name="from_name" value="yourcurator.app" />
                {/* No-JS fallback: Web3Forms redirects here after its hosted thank-you. */}
                <input type="hidden" name="redirect" value={`${siteUrl}/?registered=1#download`} />
                {/* Honeypot — hidden from humans; bots that tick it are dropped. */}
                <input type="checkbox" name="botcheck" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
                <div class="interest-row">
                  <input
                    type="email"
                    name="email"
                    required
                    placeholder="you@example.com"
                    aria-label="Your email address"
                  />
                  <select name="platform" aria-label="Your platform (optional)">
                    <option value="">Platform (optional)</option>
                    <option>macOS</option>
                    <option>Windows</option>
                    <option>Linux</option>
                  </select>
                  <button class="btn btn-lg" type="submit">Register interest</button>
                </div>
                <p class="form-status center" role="status" aria-live="polite"></p>
              </form>
            ) : (
              <div class="dl-row">
                <a class="btn btn-lg" href={interestMailto}>Register your interest</a>
              </div>
            )}
            <p class="center cta-note">Coming to Apple Silicon · Windows 10/11 · AppImage</p>
          </>
        )}
      </section>
    </main>

    <footer class="footer">
      <div class="foot-top">
        <a class="brand" href="/">
          <img src="/logo.png" width="24" height="24" alt="" />
          <span>Curator</span>
        </a>
        <nav class="foot-links">
          <a href="#features">Features</a>
          <a href="#pricing">Pricing</a>
          <a href="/news">News</a>
          <a href="#download">{launched ? "Download" : "Get notified"}</a>
          <a href="/vs-filebot">vs FileBot</a>
          <a class="foot-reddit" href="https://www.reddit.com/r/FilebotAlternative/" rel="noopener" target="_blank" aria-label="Curator community on Reddit" title="Community on Reddit">
