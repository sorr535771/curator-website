<style is:global>
  :root {
    --bg: #ffffff;
    --bg-dark: #0b0b0f;
    --ink: #14141a;
    --ink-soft: #5b5b66;
    --line: #ececf1;
    --accent: #2f6bff;
    --accent-2: #7aa2ff;
    --radius: 16px;
    --max: 1120px;
    --shadow: 0 30px 60px -25px rgba(20, 20, 40, 0.35);
  }
  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica,
      Arial, sans-serif;
    color: var(--ink);
    background: var(--bg);
    -webkit-font-smoothing: antialiased;
    line-height: 1.55;
  }
  img, video { max-width: 100%; display: block; }
  a { color: inherit; text-decoration: none; }
  h1, h2, h3 { line-height: 1.08; letter-spacing: -0.02em; margin: 0; }
  .center { text-align: center; }
  .muted { color: var(--ink-soft); }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 0.6rem;
  }
  .eyebrow.center { text-align: center; }

  .skip { position: absolute; left: -999px; }
  .skip:focus { left: 1rem; top: 1rem; background: #fff; padding: 0.5rem 1rem; z-index: 99; }

  /* Buttons */
  .btn {
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--accent); color: #fff; font-weight: 600;
    padding: 0.7rem 1.25rem; border-radius: 999px; transition: transform 0.12s ease, background 0.2s ease;
    border: 1px solid transparent; white-space: nowrap;
  }
  .btn:hover { background: #2257e0; transform: translateY(-1px); }
  .btn-lg { padding: 0.85rem 1.6rem; font-size: 1.02rem; }
  .btn-sm { padding: 0.5rem 1rem; font-size: 0.92rem; }
  .btn-ghost { background: transparent; color: var(--ink); border-color: var(--line); }
  .btn-ghost:hover { background: #f5f5f8; }
  .full { width: 100%; }

  /* Nav */
  .nav {
    position: sticky; top: 0; z-index: 50;
    display: flex; align-items: center; justify-content: space-between;
    max-width: var(--max); margin: 0 auto; padding: 0.9rem 1.5rem;
    backdrop-filter: saturate(1.4) blur(12px);
  }
  .nav::before {
    content: ""; position: absolute; inset: 0; background: rgba(255,255,255,0.72);
    border-bottom: 1px solid var(--line); z-index: -1;
  }
  .brand { display: inline-flex; align-items: center; gap: 0.55rem; font-weight: 700; font-size: 1.1rem; }
  .nav-links { display: flex; align-items: center; gap: 1.4rem; font-weight: 500; }
  .nav-links a:not(.btn):hover { color: var(--accent); }

  /* Hero */
  .hero {
    max-width: var(--max); margin: 0 auto; padding: 5rem 1.5rem 3rem; text-align: center;
  }
  .hero h1 { font-size: clamp(2.6rem, 6vw, 4.6rem); font-weight: 700; }
  .grad {
    background: linear-gradient(100deg, var(--accent), #6ba6ff);
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .lead { max-width: 640px; margin: 1.4rem auto 0; font-size: clamp(1.05rem, 2.2vw, 1.3rem); color: var(--ink-soft); }
  .cta-row { display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; margin-top: 2rem; }
  .cta-note { margin-top: 0.9rem; font-size: 0.9rem; color: var(--ink-soft); }
  .hero-media {
    margin: 3.5rem auto 0; max-width: 980px; border-radius: var(--radius);
    overflow: hidden; box-shadow: var(--shadow); border: 1px solid var(--line);
  }
  .hero-media img,
  .hero-media video { width: 100%; height: auto; display: block; }

  /* Features */
  .features { max-width: var(--max); margin: 0 auto; padding: 4rem 1.5rem; }
  .feature {
    display: grid; grid-template-columns: 1fr 1.15fr; gap: 3.5rem; align-items: center;
    padding: 3.5rem 0;
  }
  .feature.reverse .feature-copy { order: 2; }
  .feature h2 { font-size: clamp(1.7rem, 3.4vw, 2.4rem); font-weight: 700; margin-bottom: 0.9rem; }
  .feature-copy p { color: var(--ink-soft); font-size: 1.06rem; }
  .feature-shot img {
    width: 100%; border-radius: var(--radius); box-shadow: var(--shadow);
    border: 1px solid var(--line);
  }
  /* Crossfading slideshow (completion + presentation features). The first slide
     stays in flow to size the box; the rest overlay it and fade in/out. */
  .slideshow { position: relative; }
  .slideshow img { opacity: 0; transition: opacity 1s ease-in-out; }
  .slideshow img:not(:first-child) { position: absolute; inset: 0; }
  .slideshow img.active { opacity: 1; }
  @media (prefers-reduced-motion: reduce) {
    .slideshow img { transition: none; }
  }
  .ticks { list-style: none; padding: 0; margin: 1.3rem 0 0; display: grid; gap: 0.5rem; }
  .ticks li { position: relative; padding-left: 1.7rem; color: var(--ink); }
  .ticks li::before {
    content: "✓"; position: absolute; left: 0; top: 0; color: var(--accent); font-weight: 700;
  }
  .feature-note {
    margin: 1.4rem 0 0; padding: 0.85rem 1rem; font-size: 0.92rem; color: var(--ink-soft);
    background: #f5f7ff; border: 1px solid #e3e9ff; border-left: 3px solid var(--accent);
    border-radius: 10px;
  }

  /* More features (compact grid) */
  .more { max-width: var(--max); margin: 0 auto; padding: 1rem 1.5rem 4rem; }
  .more h2 { font-size: clamp(1.6rem, 3.4vw, 2.3rem); margin: 0.5rem 0 0; }
  .more-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.4rem; margin-top: 2.6rem;
  }
  .more-card {
    border: 1px solid var(--line); border-radius: 16px; padding: 1.7rem 1.6rem;
    background: #fff; transition: transform 0.12s ease, box-shadow 0.2s ease;
  }
  .more-card:hover { transform: translateY(-2px); box-shadow: 0 16px 40px -24px rgba(20,20,40,0.4); }
  .more-icon {
    width: 30px; height: 30px; color: var(--accent);
    padding: 0.5rem; background: #eef2ff; border-radius: 10px; box-sizing: content-box;
  }
  .more-card h3 { font-size: 1.15rem; margin: 1rem 0 0.5rem; letter-spacing: -0.01em; }
  .more-card p { color: var(--ink-soft); font-size: 0.98rem; margin: 0; line-height: 1.5; }

  /* Strip */
  .strip { background: var(--bg-dark); color: #f3f3f7; padding: 4.5rem 1.5rem; }
  .strip-grid {
    max-width: var(--max); margin: 0 auto; display: grid;
    grid-template-columns: repeat(4, 1fr); gap: 2.5rem;
  }
  .strip h3 { font-size: 1.15rem; margin-bottom: 0.5rem; }
  .strip p { color: #a9a9b6; font-size: 0.98rem; margin: 0; }

  /* Pricing */
  .pricing { max-width: var(--max); margin: 0 auto; padding: 5rem 1.5rem 3rem; }
  .pricing h2 { font-size: clamp(1.9rem, 4vw, 2.6rem); margin-bottom: 0.6rem; }
  .price-grid {
    display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1.6rem;
    max-width: 1040px; margin: 2rem auto 0; align-items: stretch;
  }
  .price-card {
    border: 1px solid var(--line); border-radius: 22px;
    padding: 2rem; box-shadow: var(--shadow); background: #fff;
    display: flex; flex-direction: column;
  }
  .price-card.featured { border-color: var(--accent); box-shadow: 0 10px 40px rgba(27, 67, 196, 0.18); }
  .plan-name { font-weight: 700; font-size: 1.05rem; margin: 0 0 0.6rem; display: flex; align-items: center; gap: 0.5rem; }
  .badge {
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.02em; text-transform: uppercase;
    color: #fff; background: var(--accent); border-radius: 999px; padding: 0.15rem 0.55rem;
  }
  .price-head { display: flex; align-items: baseline; gap: 0.4rem; }
  .price { font-size: 3rem; font-weight: 700; letter-spacing: -0.03em; }
  .per { color: var(--ink-soft); font-weight: 600; }
  .price-sub { color: var(--ink-soft); margin: 0.4rem 0 1.4rem; }
  .price-card .ticks { margin: 1.2rem 0 1.8rem; flex: 1 0 auto; }
  .price-foot { text-align: center; color: var(--ink-soft); font-size: 0.88rem; margin: 0.9rem 0 0; min-height: 2.7rem; }
  @media (max-width: 900px) { .price-grid { grid-template-columns: 1fr; max-width: 420px; } }

  /* Download */
  .download { max-width: var(--max); margin: 0 auto; padding: 3rem 1.5rem 5rem; }
  .download h2 { font-size: clamp(1.9rem, 4vw, 2.6rem); }
  .dl-row { display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; margin: 1.8rem 0 0.6rem; }

  /* Register-interest form (pre-launch) */
  .interest-form { margin: 1.8rem auto 0.6rem; max-width: 640px; }
  .interest-row { display: flex; gap: 0.6rem; justify-content: center; flex-wrap: wrap; }
  .interest-row input[type="email"],
  .interest-row select {
    font: inherit; color: var(--ink); background: #fff;
    border: 1px solid var(--line); border-radius: 999px;
    padding: 0.8rem 1.2rem; min-width: 0;
  }
  .interest-row input[type="email"] { flex: 1 1 220px; }
  .interest-row input[type="email"]:focus,
  .interest-row select:focus { outline: 2px solid var(--accent); outline-offset: 1px; }
  .interest-form .hp { position: absolute; left: -9999px; }
  .form-status { min-height: 1.4em; margin: 0.8rem 0 0; font-weight: 600; }
  .form-status.ok { color: #1a7f37; }
  .form-status.err { color: #b42318; }

  /* Footer */
  .footer { border-top: 1px solid var(--line); padding: 3rem 1.5rem; max-width: var(--max); margin: 0 auto; }
  .foot-top { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; }
  .foot-links { display: flex; align-items: center; gap: 1.4rem; color: var(--ink-soft); }
  .foot-links a:hover { color: var(--accent); }
  .foot-reddit { display: inline-flex; align-items: center; }
  .attrib { color: var(--ink-soft); font-size: 0.86rem; margin: 1.6rem 0 0.4rem; max-width: 640px; }
  .attrib a { color: var(--ink); text-decoration: underline; text-underline-offset: 2px; }
  .copy { color: var(--ink-soft); font-size: 0.86rem; margin: 0; }

  /* Responsive */
  @media (max-width: 800px) {
    .nav-links a:not(.btn) { display: none; }
    .feature { grid-template-columns: 1fr; gap: 1.8rem; padding: 2.5rem 0; }
    .feature.reverse .feature-copy { order: 0; }
    .strip-grid { grid-template-columns: 1fr 1fr; gap: 1.8rem; }
  }
  @media (max-width: 480px) {
    .strip-grid { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    .hero-media { margin-top: 2.5rem; }
  }
</style>

<script>
  // Keep the footer year current without a build step.
  const y = document.getElementById("yr");
  if (y) y.textContent = String(new Date().getFullYear());

  // Nudge the hero video to autoplay. Safari/WebKit can ignore the `muted`
  // attribute when it comes from server-rendered HTML and then block muted
  // autoplay; forcing the property and calling play() reliably starts it.
  const hero = document.querySelector(".hero-media video");
  if (hero) {
    hero.muted = true;
    hero.playsInline = true;
    const tryPlay = () => { const p = hero.play(); if (p) p.catch(() => {}); };
    tryPlay();
    hero.addEventListener("loadeddata", tryPlay, { once: true });
    hero.addEventListener("canplay", tryPlay, { once: true });
    // Last resort if a strict policy still blocks it: start on first interaction.
    ["pointerdown", "touchstart", "scroll", "keydown"].forEach((e) =>
      document.addEventListener(e, tryPlay, { once: true, passive: true }),
    );
  }

  // Register-interest form (pre-launch): submit to Web3Forms via fetch and show
  // the result inline. If fetch itself fails (network/extension), fall back to a
  // native POST — Web3Forms then shows its hosted thank-you and redirects back
  // (the `redirect` hidden field). `?registered=1` covers that no-JS/fallback
  // return trip with the same inline message.
  const interestForm = document.getElementById("interest-form") as HTMLFormElement | null;
  if (interestForm) {
    const status = interestForm.querySelector(".form-status") as HTMLElement;
    const showOk = () => {
      status.textContent = "Thanks — you're on the list. We'll email you when Curator ships.";
      status.classList.add("ok");
      (interestForm.querySelector(".interest-row") as HTMLElement).style.display = "none";
    };
    if (new URLSearchParams(location.search).get("registered") === "1") showOk();
    interestForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      status.textContent = "Sending…";
      status.classList.remove("ok", "err");
      try {
        const res = await fetch(interestForm.action, {
          method: "POST",
          body: new FormData(interestForm),
          headers: { Accept: "application/json" },
        });
        const data = await res.json();
        if (data.success) {
          showOk();
        } else {
          status.textContent = data.message || "Something went wrong — please try again.";
          status.classList.add("err");
        }
      } catch {
        interestForm.submit(); // native fallback → hosted thank-you → redirect back
      }
    });
  }

  // Crossfade each feature slideshow through its slides on a timer. Skipped when
  // the visitor prefers reduced motion (CSS also disables the fade then).
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (!reduceMotion) {
    document.querySelectorAll(".slideshow").forEach((sl) => {
      const imgs = Array.from(sl.querySelectorAll("img"));
      if (imgs.length < 2) return;
      let i = 0;
      setInterval(() => {
        imgs[i].classList.remove("active");
        i = (i + 1) % imgs.length;
        imgs[i].classList.add("active");
      }, 2800);
    });
  }
</script>

<!-- Paddle Checkout — LIVE/production (env + token set in the frontmatter).
     Only loaded once `launched` is true: pre-launch there are no Buy buttons,
     so the live checkout script isn't shipped at all. -->
{launched && <script is:inline src="https://cdn.paddle.com/paddle/v2/paddle.js"></script>}
{launched && (
  <script define:vars={{ paddleEnv, paddleToken }}>
    // Wait for paddle.js (loaded just above) to be ready, then open the hosted
    // checkout for the clicked plan's price id.
    function wirePaddle() {
      if (!window.Paddle) {
        setTimeout(wirePaddle, 200);
        return;
      }
      window.Paddle.Environment.set(paddleEnv);
      window.Paddle.Initialize({ token: paddleToken });
      document.querySelectorAll(".buy").forEach((btn) => {
        btn.addEventListener("click", () => {
          const priceId = btn.getAttribute("data-price");
          if (priceId) {
            window.Paddle.Checkout.open({ items: [{ priceId, quantity: 1 }] });
          }
        });
      });
    }
    wirePaddle();
  </script>
)}
